{
  "info": {
    "name": "ERP SaaS - Backend API",
    "_postman_id": "erp-saas-collection-v1",
    "description": "Full API collection for ERP SaaS Laravel backend.\n\n**Base URLs:**\n- Central API: `http://erp.test:8000`\n- Tenant API: `http://alpha.erp.test:8000`\n\n**Auth:**\n- Super Admin routes use `Bearer {{super_admin_token}}`\n- Tenant routes use `Bearer {{tenant_token}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",          "value": "http://erp.test:8000",       "type": "string" },
    { "key": "tenant_url",        "value": "http://alpha.erp.test:8000", "type": "string" },
    { "key": "super_admin_token", "value": "",                           "type": "string" },
    { "key": "tenant_token",      "value": "",                           "type": "string" }
  ],
  "item": [

    {
      "name": "🏰 Super Admin — Auth",
      "item": [
        {
          "name": "Login (Email + Password)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('super_admin_token', pm.response.json().token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/admin/auth/login", "host": ["{{base_url}}"], "path": ["api","admin","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmednassag@gmail.com\",\n  \"password\": \"password\"\n}" }
          }
        },
        {
          "name": "Send Email OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/admin/auth/email-otp/send", "host": ["{{base_url}}"], "path": ["api","admin","auth","email-otp","send"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmednassag@gmail.com\"\n}" }
          }
        },
        {
          "name": "Verify Email OTP",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('super_admin_token', pm.response.json().token); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/admin/auth/email-otp/verify", "host": ["{{base_url}}"], "path": ["api","admin","auth","email-otp","verify"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmednassag@gmail.com\",\n  \"otp\": \"123456\"\n}" }
          }
        },
        {
          "name": "Send Mobile OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/admin/auth/mobile-otp/send", "host": ["{{base_url}}"], "path": ["api","admin","auth","mobile-otp","send"] },
