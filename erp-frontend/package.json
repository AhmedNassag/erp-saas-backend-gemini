{
  "name": "nexaerp-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "NexaERP Frontend Monorepo",
  "scripts": {
    "dev:portfolio": "pnpm --filter @nexaerp/portfolio dev",
    "dev:admin":     "pnpm --filter @nexaerp/admin dev",
    "dev:tenant":    "pnpm --filter @nexaerp/tenant dev",
    "dev:all":       "pnpm --parallel --filter \"./apps/*\" dev",
    "build:all":     "pnpm --filter \"./apps/*\" build",
    "lint":          "pnpm -r lint"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
